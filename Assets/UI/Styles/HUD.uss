.score-container {
    width: 60%;
    height: 15%;
    position: Relative;
    top: 5%;
    left: 20%;
    flex-direction: row;
    justify-content: space-around;
    align-items: center;
    padding-top: 20px; 
}

.score-label {
    width: 100px;
    font-size: 175px;
    color: white;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
}