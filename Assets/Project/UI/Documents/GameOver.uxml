<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="gameOver-container" style="flex-grow: 1; display: none;">
        <ui:Label text="Victoria para el Jugador 1" name="gameOver-text" style="overflow: hidden; color: rgb(255, 255, 255); -unity-font-style: bold; font-size: 60px; -unity-text-align: middle-center; background-color: rgb(0, 0, 0); height: auto; align-self: center; top: 40%;"/>
        <ui:GroupBox name="buttons-group" style="align-self: center; justify-content: space-around; background-color: rgb(0, 0, 0); bottom: 20px; position: absolute; height: 357px; width: 297px; left: auto;">
            <ui:Button text="Volver a empezar" name="restart-button" style="height: 25%; background-color: rgb(30, 130, 255); color: rgb(255, 255, 255); border-top-width: 0; border-top-right-radius: 6px; border-right-width: 0; border-bottom-right-radius: 6px; border-bottom-width: 0; border-bottom-left-radius: 6px; border-left-width: 0; border-top-left-radius: 6px;"/>
            <ui:Button text="Menú principal" name="mainMenu-button" style="height: 25%; background-color: rgb(180, 40, 40); color: rgb(255, 255, 255); border-bottom-width: 0; border-bottom-right-radius: 6px; border-right-width: 0; border-top-right-radius: 6px; border-top-width: 0; border-top-left-radius: 6px; border-left-width: 0; border-bottom-left-radius: 6px;"/>
        </ui:GroupBox>
    </ui:VisualElement>
</ui:UXML>
